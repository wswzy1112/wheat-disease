# 生产环境配置
# 复制此文件为 .env 并填写实际值

# Flask 密钥（生产环境必须修改！）
SECRET_KEY=your-random-secret-key-here-change-it

# 数据库连接
# 格式: mysql+pymysql://用户名:密码@主机/数据库名
DATABASE_URL=mysql+pymysql://root:password@localhost/wheat_disease

# 服务端口
PORT=5000

# 运行环境: development | production
FLASK_ENV=production

# 允许的前端域名（逗号分隔，生产环境必须设置）
# 例如: https://wheat.yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=

# JWT 令牌有效期（小时）
JWT_EXPIRATION_HOURS=24

# 模型文件路径（默认使用项目内路径）
# MODEL_PATH=model/model/cnn_model.pth
# LABEL_PATH=model/model/labels.json

# 上传文件存储目录
# UPLOAD_FOLDER=static/uploads
